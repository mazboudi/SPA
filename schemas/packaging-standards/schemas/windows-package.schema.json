{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packaging-standards/schemas/windows-package.schema.json",
  "title": "Windows Package Metadata",
  "description": "Platform-specific packaging metadata for Windows titles. Located at windows/package.yaml in each title repo.",
  "type": "object",
  "required": [
    "version",
    "packaging_version",
    "installer_type",
    "install",
    "uninstall",
    "detection"
  ],
  "additionalProperties": false,
  "properties": {
    "package_id": {
      "type": "string",
      "description": "Unique kebab-case identifier matching the title's app.json package_id."
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable name including version (e.g. '7-Zip 26.00')."
    },
    "version": {
      "type": "string",
      "description": "The installer's vendor version string (e.g. '26.00', '134.0.6998.89')."
    },
    "packaging_version": {
      "type": ["string", "integer"],
      "description": "Internal packaging iteration. Increment when re-packaging without a vendor version change."
    },
    "installer_type": {
      "type": "string",
      "enum": ["msi", "exe", "msix", "ps1"],
      "description": "Type of installer file."
    },
    "install": {
      "type": "object",
      "description": "Install command and return code configuration.",
      "required": ["command_line"],
      "additionalProperties": false,
      "properties": {
        "command_line": {
          "type": "string",
          "description": "Silent install command line (e.g. 'msiexec.exe /i \"Files\\7z2600-x64.msi\" /qn /norestart')."
        },
        "return_codes": {
          "type": "object",
          "description": "Return code classification.",
          "additionalProperties": false,
          "properties": {
            "success":     { "type": "array", "items": { "type": "integer" } },
            "soft_reboot": { "type": "array", "items": { "type": "integer" } },
            "hard_reboot": { "type": "array", "items": { "type": "integer" } },
            "retry":       { "type": "array", "items": { "type": "integer" } }
          }
        }
      }
    },
    "uninstall": {
      "type": "object",
      "description": "Uninstall command and return code configuration.",
      "required": ["command_line"],
      "additionalProperties": false,
      "properties": {
        "command_line": {
          "type": "string",
          "description": "Silent uninstall command line."
        },
        "return_codes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "success":     { "type": "array", "items": { "type": "integer" } },
            "soft_reboot": { "type": "array", "items": { "type": "integer" } }
          }
        }
      }
    },
    "detection_mode": {
      "type": "string",
      "enum": ["registry-marker", "file", "msi-product-code", "script"],
      "description": "Detection method used when building Intune detection rules.",
      "default": "registry-marker"
    },
    "detection": {
      "type": "object",
      "description": "Detection parameters. Required keys vary by detection_mode.",
      "additionalProperties": true,
      "properties": {
        "registry": {
          "type": "object",
          "description": "Used when detection_mode is 'registry-marker'.",
          "required": ["hive", "key_path", "value_name"],
          "additionalProperties": false,
          "properties": {
            "hive":       { "type": "string", "enum": ["HKLM", "HKCU", "HKCR"] },
            "key_path":   { "type": "string" },
            "value_name": { "type": "string" },
            "operator":   { "type": "string", "enum": ["exists", "notExists", "equal", "notEqual", "greaterThanOrEqual"], "default": "exists" },
            "value":      { "type": "string" }
          }
        },
        "file": {
          "type": "object",
          "description": "Used when detection_mode is 'file'.",
          "required": ["path", "file_or_folder"],
          "additionalProperties": false,
          "properties": {
            "path":               { "type": "string" },
            "file_or_folder":     { "type": "string" },
            "operator":           { "type": "string", "enum": ["exists", "notExists", "equal", "greaterThanOrEqual"], "default": "exists" },
            "version":            { "type": "string" },
            "check32BitOn64System": { "type": "boolean", "default": false }
          }
        },
        "msi": {
          "type": "object",
          "description": "Used when detection_mode is 'msi-product-code'.",
          "required": ["product_code"],
          "additionalProperties": false,
          "properties": {
            "product_code":    { "type": "string", "pattern": "^\\{[A-Fa-f0-9\\-]{36}\\}$" },
            "version_operator":{ "type": "string", "enum": ["greaterThanOrEqual", "equal"], "default": "greaterThanOrEqual" },
            "version":         { "type": "string" }
          }
        }
      }
    },
    "intune": {
      "type": "object",
      "description": "Optional Intune-specific overrides. Primary Intune metadata lives in windows/intune/app.json.",
      "additionalProperties": true,
      "properties": {
        "display_name":                   { "type": "string" },
        "description":                    { "type": "string" },
        "restart_behavior":               { "type": "string", "enum": ["basedOnReturnCode", "allow", "suppress", "force"] },
        "install_experience":             { "type": "string", "enum": ["system", "user"] },
        "max_run_time_in_minutes":        { "type": "integer", "minimum": 5, "maximum": 1440 },
        "allowed_to_reinstall":           { "type": "boolean" },
        "uninstall_previous_version_of_app": { "type": "boolean" }
      }
    }
  }
}