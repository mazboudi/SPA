{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packaging-standards/schemas/windows-package.schema.json",
  "title": "Windows Package Metadata",
  "description": "Platform-specific packaging metadata for Windows titles. Located at windows/package.yaml in each title repo.",
  "type": "object",
  "required": [
    "version",
    "packaging_version",
    "installer_type",
    "install_command",
    "uninstall_command",
    "detection"
  ],
  "properties": {
    "package_id": {
      "type": "string",
      "description": "Unique kebab-case identifier matching the title's app.json package_id."
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable name including version (e.g. '7-Zip 26.00')."
    },
    "version": {
      "type": "string",
      "description": "The installer's vendor version string (e.g. '26.00', '134.0.6998.89')."
    },
    "vendor_version": {
      "type": "string",
      "description": "Alias for version. Deprecated — prefer 'version'."
    },
    "packaging_version": {
      "type": ["string", "integer"],
      "description": "Internal packaging iteration. Increment when re-packaging without a vendor version change."
    },
    "installer_type": {
      "type": "string",
      "enum": ["msi", "exe", "msix", "ps1"],
      "description": "Type of installer file."
    },
    "source_filename": {
      "type": "string",
      "description": "Filename of the installer binary inside the src/Files directory."
    },
    "install_command": {
      "type": "string",
      "description": "Silent install command line (e.g. 'msiexec.exe /i \"Files\\7z2600-x64.msi\" /qn /norestart')."
    },
    "uninstall_command": {
      "type": "string",
      "description": "Silent uninstall command line."
    },
    "detection_mode": {
      "type": "string",
      "enum": ["registry-marker", "file", "msi-product-code", "script"],
      "description": "Detection method used when building Intune detection rules.",
      "default": "registry-marker"
    },
    "detection": {
      "type": "object",
      "description": "Detection parameters. Required keys vary by detection_mode. For msi-product-code: product_code, version, version_operator. For registry-marker: registry sub-object. For file: file sub-object.",
      "additionalProperties": true,
      "properties": {
        "product_code": {
          "type": "string",
          "description": "MSI product code GUID. Used when detection_mode is 'msi-product-code'."
        },
        "version_operator": {
          "type": "string",
          "enum": ["greaterThanOrEqual", "equal"],
          "default": "greaterThanOrEqual",
          "description": "Version comparison operator for MSI detection."
        },
        "version": {
          "type": "string",
          "description": "Expected version string for MSI detection."
        },
        "registry": {
          "type": "object",
          "description": "Used when detection_mode is 'registry-marker'.",
          "required": ["hive", "key_path", "value_name"],
          "additionalProperties": false,
          "properties": {
            "hive":       { "type": "string", "enum": ["HKLM", "HKCU", "HKCR"] },
            "key_path":   { "type": "string" },
            "value_name": { "type": "string" },
            "operator":   { "type": "string", "enum": ["exists", "notExists", "equal", "notEqual", "greaterThanOrEqual"], "default": "exists" },
            "value":      { "type": "string" }
          }
        },
        "file": {
          "type": "object",
          "description": "Used when detection_mode is 'file'.",
          "required": ["path", "file_or_folder"],
          "additionalProperties": false,
          "properties": {
            "path":               { "type": "string" },
            "file_or_folder":     { "type": "string" },
            "operator":           { "type": "string", "enum": ["exists", "notExists", "equal", "greaterThanOrEqual"], "default": "exists" },
            "version":            { "type": "string" },
            "check32BitOn64System": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "max_runtime_minutes": {
      "type": "integer",
      "minimum": 5,
      "maximum": 1440,
      "description": "Maximum time in minutes the install is allowed to run before Intune marks it as failed."
    },
    "restart_behavior": {
      "type": "string",
      "enum": ["basedOnReturnCode", "allow", "suppress", "force"],
      "description": "Device restart behavior after install."
    },
    "install_experience": {
      "type": "string",
      "enum": ["system", "user"],
      "description": "Install execution context."
    },
    "intune": {
      "type": "object",
      "description": "Optional Intune-specific overrides. Primary Intune metadata lives in windows/intune/app.json.",
      "additionalProperties": true,
      "properties": {
        "display_name":                   { "type": "string" },
        "description":                    { "type": "string" },
        "restart_behavior":               { "type": "string", "enum": ["basedOnReturnCode", "allow", "suppress", "force"] },
        "install_experience":             { "type": "string", "enum": ["system", "user"] },
        "max_run_time_in_minutes":        { "type": "integer", "minimum": 5, "maximum": 1440 },
        "allowed_to_reinstall":           { "type": "boolean" },
        "uninstall_previous_version_of_app": { "type": "boolean" }
      }
    },
    "return_codes": {
      "type": "array",
      "description": "Custom return code mappings. Each entry specifies a code and its interpretation.",
      "items": {
        "type": "object",
        "required": ["returnCode", "type"],
        "additionalProperties": false,
        "properties": {
          "returnCode": { "type": "integer", "description": "Process exit code." },
          "type": {
            "type": "string",
            "enum": ["success", "softReboot", "hardReboot", "retry", "failed"],
            "description": "How Intune should interpret this exit code."
          }
        }
      }
    },
    "close_apps": {
      "type": "string",
      "description": "Comma-separated list of process names to close before install/uninstall (e.g. 'chrome,msedge')."
    },
    "supersedes": {
      "type": "object",
      "description": "Supersedence configuration for replacing a prior Intune app.",
      "additionalProperties": false,
      "properties": {
        "app_id": {
          "type": "string",
          "description": "Intune App ID of the title this supersedes."
        },
        "uninstall_previous": {
          "type": "boolean",
          "default": true,
          "description": "Whether to uninstall the previous version before installing this one."
        }
      }
    }
  },
  "additionalProperties": false
}